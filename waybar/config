{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // Choose the order of the modules
    "modules-left": ["custom/logo", "sway/workspaces", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/recording", "custom/updates", "tray", "cpu", "memory", "pulseaudio", "backlight", "battery", "bluetooth", "network", "custom/power"],
    "custom/logo": {
        "tooltip": false,
        "format": "у°ЈҮ"
    },
    "sway/workspaces": {
        "disable-scroll": true,
        "sort-by-name": true,
        "on-click": "activate",
        "format": "{name} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "у°ЈҶ",
        "window-format": "<span color='#e0e0e0'>{name}</span>",
        "window-rewrite": {
          "class<google-chrome>": "пүЁ",
          "class<vivaldi-stable>": "оқ…",
          "class<chromium-browser>": "оқғ",
          "class<kitty>": "п’ү",
          "class<wechat>": "пҮ—",
          "class<qq>": "пҮ–",
          "class<obsidian>": "уұһҒ",
          "class<steam>": "пҶ¶",
          "class<org.gnome.Calculator>": "пҮ¬"
        }
    },
    "sway/window": {
        "format": "рҹ‘ү {title}",
        "max-length": 50,
        "ellipsis": true
    },
    "clock": {
        "timezone": "Asia/Shanghai",
        "format": "оӘ° {:%m-%d пҖ— %H:%M %a}",
        "format-alt": "оӘ° {:%Y-%m-%d пҖ— %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/recording": {
        "exec": "if [ -f /tmp/wf-recorder.pid ] && kill -0 $(cat /tmp/wf-recorder.pid) 2>/dev/null; then echo '{\"text\": \"в—Ҹ REC\", \"class\": \"recording\"}'; else echo '{\"text\": \"\", \"class\": \"\"}'; fi",
        "return-type": "json",
        "interval": 1,
        "tooltip": false
    },
    "custom/updates": {
        "exec": "count=$(sudo pacman -Qu | wc -l); if [ \"$count\" -gt 0 ]; then echo \"{\\\"text\\\": \\\"$count\\\", \\\"tooltip\\\": \\\"жңү $count дёӘеҢ…йңҖиҰҒжӣҙж–°\\\"}\"; fi",
        "return-type": "json",
        "interval": 1800,
        "format": "у°Ҹ• {}",
        "on-click": "kitty --title yay -e yay -Syu --noconfirm",
        "signal": 8
    },
    "tray": {
        "spacing": 8
    },
    "cpu": {
        "interval": 5,
        "format": "у°Қӣ {usage}%",
        "tooltip": false,
        "on-click": "kitty --class btop-float -e btop"
    },
    "memory": {
        "interval": 5,
        "format": "оҝ… {used}G",
        "tooltip-format": "Memory: {used}GiB used of {total}GiB ({percentage}%)",
        "on-click": "kitty --class htop-float -e htop"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "п‘Ұ",
        "format-icons": {
            "default": ["пҖҰ", "пҖ§", "пҖЁ "]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },
    "battery": {
        "interval": 5,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "уұ§Ұ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-full": "уұҹў",
        "format-icons": ["у°ӮҺ", "у°Ғә", "у°Ғ»", "у°Ғј", "у°ҒҪ", "у°Ғҫ", "у°Ғҝ", "у°ӮҖ", "у°ӮҒ", "у°ӮӮ", "у°Ғ№"]
    },
    "bluetooth": {
      "format": "пҠ”",
      "format-disabled": "у°ӮІ",
      "format-connected": "пҠ”",
      "tooltip-format": "Devices connected: {num_connections}",
      "on-click": "blueberry"
    },
    "network": {
        "interval": 3,
        "format-wifi": "пҮ« {essid}",
        "format-ethernet": "у°ҲҖ",
        "format-disconnected": "у°–Ә",
        "tooltip-format-wifi": "{essid} ({frequency} GHz)\nвҮЈ{bandwidthDownBytes}  вҮЎ{bandwidthUpBytes}",
        "tooltip-format-ethernet": "вҮЈ{bandwidthDownBytes}  вҮЎ{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "sleep 0.15 && ~/dotfiles/scripts/fuzzel-wifimenu.sh"
    },
    "custom/power": {
        "tooltip": false,
        "format": "пҖ‘",
        "on-click": "sleep 0.15 && ~/dotfiles/scripts/fuzzel-powermenu.sh"
    }
}
