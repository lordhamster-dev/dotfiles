{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "custom/window"],
    "modules-center": ["custom/music"],
    "modules-right": ["tray", "pulseaudio", "backlight", "battery", "clock","custom/lock", "custom/power"],
    "hyprland/workspaces": {
         "disable-scroll": true,
         "sort-by-name": true,
         "format": " {icon} ",
         "format-icons": {
             "default": "о®ґ",
         },
     },
    "custom/window": {
        "exec": "~/.config/waybar/scripts/window.sh",
        "interval": 1,
        "format": "{}",
        "max-length": 30,
        "ellipsis": true
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "custom/music": {
        "format": "пЂЃ  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 50
    },
    "clock": {
        "timezone": "Asia/Shanghai",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "оЄ° {:%Y-%m-%d}",
        "format": "пЂ— {:%H:%M}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "п–ѓ",
        "format-plugged": "п–ѓ",
        "format-alt": "{icon}",
        "format-icons": ["п–‚", "п•№",  "п•є", "п•»", "п•ј", "п•Ѕ", "п•Ѕ", "п•ѕ", "п•ї", "п–Ђ", "п–Ѓ", "п•ё"]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "п‘¦",
        "format-icons": {
            "default": ["пЂ¦", "пЂ§", "пЂЁ "]
        },
        "on-click": "pavucontrol"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "hyprlock",
        "format": "пЂЈ",
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "sleep 0.15 && ~/.config/waybar/scripts/powermenu.sh",
        "format": "пЂ‘"
    }
}
